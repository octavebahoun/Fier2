@baseUrl = https://backend-fieri.vercel.app
@contentType = application/json

### ------------------------------------------------------------
### 🔒 MODULE 1 : AUTHENTICATION & SESSION
### ------------------------------------------------------------

# @name register
# Inscription d'un nouveau membre (Chercheur, Étudiant, etc.)
POST {{baseUrl}}/auth/register
Content-Type: {{contentType}}

{
    "email": "chercheur.test@fieri.org",
    "password": "SecurePassword123!",
    "firstName": "Alexandre",
    "lastName": "Vidal",
    "branchId": 1,
    "role": "CHERCHEUR"
}

###

# @name login
# Connexion pour obtenir le jeton JWT
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
    "email": "chercheur.test@fieri.org",
    "password": "SecurePassword123!"
}

### Capture automatique du Token après le login (utilisé pour les routes sécurisées)
@authToken = {{login.response.body.data.access_token}}

###

# @name getProfile
# Récupérer les informations de session du membre connecté
GET {{baseUrl}}/members/me
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}


### ------------------------------------------------------------
### 🏛️ MODULE 2 : ORGANIZATIONS (Routes Publiques)
### ------------------------------------------------------------

# @name getCountries
# Récupérer tous les pays d'implantation
GET {{baseUrl}}/countries
Content-Type: {{contentType}}

###

# @name getCountryById
# Récupérer le détail d'un pays
GET {{baseUrl}}/countries/1
Content-Type: {{contentType}}

###

# @name getUniversities
# Récupérer les universités liées à un pays
GET {{baseUrl}}/countries/1/universities
Content-Type: {{contentType}}

###

# @name getBranches
# Récupérer les branches/filières liées à une université
GET {{baseUrl}}/universities/1/branches
Content-Type: {{contentType}}


### ------------------------------------------------------------
### 🔬 MODULE 3 : PROJETS DE RECHERCHE R&D
### ------------------------------------------------------------

# @name getProjects
# Récupérer la liste des projets (Filtres optionnels : ?clubId=club-1&status=Actif&search=Rover)
GET {{baseUrl}}/projects
Content-Type: {{contentType}}

###

# @name getProjectById
# Récupérer le détail d'un projet de recherche
GET {{baseUrl}}/projects/proj-101
Content-Type: {{contentType}}

###

# @name toggleProjectStar
# Suivre ou ne plus suivre un projet (Favori)
POST {{baseUrl}}/projects/proj-101/follow
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name supportProject
# Soutenir financièrement (Don participatif fictif) un projet
POST {{baseUrl}}/projects/proj-101/support
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
    "amount": 150,
    "message": "Excellent projet, continuez ainsi !"
}


### ------------------------------------------------------------
### 🏛️ MODULE 4 : CLUBS & PÔLES DE RECHERCHE
### ------------------------------------------------------------

# @name getClubs
# Récupérer la liste de tous les clubs
GET {{baseUrl}}/clubs
Content-Type: {{contentType}}

###

# @name getClubById
# Récupérer les détails d'un club (membres, projets, publications...)
GET {{baseUrl}}/clubs/club-1
Content-Type: {{contentType}}

###

# @name joinClubDirect
# Rejoindre un club en mode direct (Ancien workflow)
POST {{baseUrl}}/clubs/club-1/join
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name leaveClubDirect
# Quitter un club en direct (Ancien workflow)
DELETE {{baseUrl}}/clubs/club-1/join
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}


### ------------------------------------------------------------
### 🎓 MODULE 5 : ACADÉMIE & FORMATIONS
### ------------------------------------------------------------

# @name getWorkshops
# Récupérer la liste des ateliers et formations
GET {{baseUrl}}/workshops
Content-Type: {{contentType}}

###

# @name registerToWorkshop
# S'inscrire à un atelier (Gère automatiquement la file d'attente si complet)
POST {{baseUrl}}/workshops/work-101/register
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
    "userFullName": "Alexandre Vidal"
}

###

# @name unregisterFromWorkshop
# Se désinscrire d'un atelier (Libère la place et promeut le premier sur liste d'attente)
DELETE {{baseUrl}}/workshops/work-101/register
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}


### ------------------------------------------------------------
### 📅 MODULE 6 : ÉVÉNEMENTS & CONCOURS
### ------------------------------------------------------------

# @name getEvents
# Récupérer le catalogue des événements scientifiques
GET {{baseUrl}}/events
Content-Type: {{contentType}}

###

# @name registerToEvent
# S'inscrire à un événement (Génération ticket / lien live)
POST {{baseUrl}}/events/event-101/register
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}


### ------------------------------------------------------------
### 👤 MODULE 7 : ANNUAIRE DES CHERCHEURS
### ------------------------------------------------------------

# @name getResearchers
# Récupérer la liste des profils de chercheurs publics
GET {{baseUrl}}/researchers
Content-Type: {{contentType}}

###

# @name getResearcherById
# Récupérer le profil détaillé d'un chercheur (biographie, distinctions, projets)
GET {{baseUrl}}/researchers/101
Content-Type: {{contentType}}

###

# @name getMyProfileDetails
# Récupérer ma fiche chercheur détaillée
GET {{baseUrl}}/researchers/me
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name updateMyProfile
# Mettre à jour mon profil chercheur public
PUT {{baseUrl}}/researchers/me
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
    "bio": "Expert en intelligence artificielle et apprentissage profond.",
    "skills": ["Python", "PyTorch", "SLAM", "Computer Vision"],
    "avatarUrl": "https://images.unsplash.com/photo-1534528741775-53994a69daeb"
}

###

# @name followResearcher
# S'abonner aux travaux d'un chercheur
POST {{baseUrl}}/researchers/101/follow
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}


### ------------------------------------------------------------
### 📰 MODULE 8 : ACTUALITÉS & VEILLE SCIENTIFIQUE
### ------------------------------------------------------------

# @name getNews
# Récupérer les actualités approuvées (?includePending=true pour les éditeurs/admins)
GET {{baseUrl}}/news?includePending=false
Content-Type: {{contentType}}

###

# @name getNewsById
# Détail d'un article
GET {{baseUrl}}/news/news-101
Content-Type: {{contentType}}

###

# @name submitNews
# Proposer un nouvel article (Statut initial par défaut : PENDING)
POST {{baseUrl}}/news
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
    "title": "Avancées majeures en Fusion Nucléaire au Bénin",
    "content": "Des chercheurs du pôle physique ont stabilisé un plasma...",
    "category": "Physique",
    "imageUrl": "https://images.unsplash.com/photo-1507668077129-56e32842fceb"
}

###

# @name approveNews
# Approuver un article proposé (Admin / Responsable uniquement)
PATCH {{baseUrl}}/news/news-101/approve
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name rejectNews
# Supprimer ou rejeter un article proposé (Admin / Créateur uniquement)
DELETE {{baseUrl}}/news/news-101
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}


### ------------------------------------------------------------
### 📊 MODULE 9 : TABLEAU DE BORD & STATS
### ------------------------------------------------------------

# @name getDashboardStats
# Récupérer les statistiques globales de l'utilisateur (Activités, abonnements)
GET {{baseUrl}}/dashboard/me
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name getNotifications
# Récupérer mes notifications push reçues
GET {{baseUrl}}/notifications
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name markNotificationAsRead
# Marquer une notification spécifique comme lue
PUT {{baseUrl}}/notifications/notif-101/read
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}


### ------------------------------------------------------------
### 📬 MODULE 10 : FORMULAIRE DE CONTACT
### ------------------------------------------------------------

# @name sendContactMessage
# Envoyer un message au support ou à l'équipe Fieri
POST {{baseUrl}}/contact
Content-Type: {{contentType}}

{
    "name": "Professeur Dupont",
    "email": "dupont@sorbonne.fr",
    "subject": "Proposition de Partenariat R&D",
    "message": "Bonjour, je souhaiterais connecter nos laboratoires avec votre plateforme..."
}


### ------------------------------------------------------------
### 💼 MODULE 11 : KANBAN DES TÂCHES PROJET
### ------------------------------------------------------------

# @name getTasksByProject
# Récupérer la liste des tâches Kanban d'un projet spécifique
GET {{baseUrl}}/tasks/project/proj-101
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name createTask
# Créer une nouvelle tâche de projet (Chef de projet uniquement)
POST {{baseUrl}}/tasks
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
    "projectId": "proj-101",
    "title": "Intégration du capteur LiDAR",
    "status": "TODO",
    "priority": "HIGH",
    "assignedTo": "Alexandre Vidal"
}

###

# @name updateTaskStatus
# Modifier l'état d'avancement d'une tâche (TODO, IN_PROGRESS, REVIEW, DONE)
PUT {{baseUrl}}/tasks/task-101
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
    "status": "IN_PROGRESS"
}

###

# @name assignTask
# Assigner une tâche à un collaborateur
PATCH {{baseUrl}}/tasks/task-101/assign
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
    "assignedTo": "Tisto Dev"
}

###

# @name setTaskPriority
# Ajuster la priorité d'une tâche (LOW, MEDIUM, HIGH)
PATCH {{baseUrl}}/tasks/task-101/priority
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
    "priority": "MEDIUM"
}

###

# @name deleteTask
# Supprimer définitivement une tâche
DELETE {{baseUrl}}/tasks/task-101
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}


### ------------------------------------------------------------
### 🏅 MODULE 12 : SYSTÈME DE BADGES DE VALORISATION
### ------------------------------------------------------------

# @name getBadgesByUser
# Récupérer les badges attribués à un utilisateur
GET {{baseUrl}}/badges/user/101
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name awardBadge
# Attribuer un badge de mérite à un chercheur (Admin/Mentor uniquement)
POST {{baseUrl}}/badges/award
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
    "userId": 101,
    "userName": "Alexandre Vidal",
    "badgeType": "CONTRIBUTOR_GOLD",
    "awardedBy": "Conseil Scientifique"
}

###

# @name revokeBadge
# Retirer un badge précédemment accordé
DELETE {{baseUrl}}/badges/badge-101
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}


### ------------------------------------------------------------
### 🤝 MODULE 13 : ADHÉSIONS CLUBS (WORKFLOW DE VALIDATION)
### ------------------------------------------------------------

# @name requestJoinClub
# Soumettre une demande d'adhésion à un club (Statut initial : PENDING)
POST {{baseUrl}}/memberships/requests
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
    "clubId": "club-1",
    "user": {
        "id": 101,
        "email": "chercheur.test@fieri.org",
        "firstName": "Alexandre",
        "lastName": "Vidal"
    }
}

###

# @name getPendingRequests
# Consulter les demandes d'adhésion en attente pour un club (Réservé Responsable/Admin)
GET {{baseUrl}}/memberships/requests/pending/club-1
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name getAllRequestsByClub
# Consulter l'historique complet (acceptés/refusés/en attente) d'un club
GET {{baseUrl}}/memberships/requests/club/club-1
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name getUserRequests
# Récupérer mes demandes d'adhésion en cours
GET {{baseUrl}}/memberships/requests/user/101
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name approveJoinRequest
# Accepter une demande d'adhésion (Ajoute le membre au club)
PATCH {{baseUrl}}/memberships/requests/req-101/approve
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name rejectJoinRequest
# Refuser une demande d'adhésion
PATCH {{baseUrl}}/memberships/requests/req-101/reject
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name leaveClub
# Quitter volontairement un club
DELETE {{baseUrl}}/memberships/club-1/user/101
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}


### ------------------------------------------------------------
### 💼 MODULE 14 : OPPORTUNITÉS & CANDIDATURES
### ------------------------------------------------------------

# @name submitApplication
# Postuler à un projet ou une opportunité
POST {{baseUrl}}/applications
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
    "opportunityId": "opp-201",
    "coverLetter": "Je souhaite contribuer sur le développement de l'interface ROS2...",
    "cvUrl": "https://storage.fieri.org/cv-vidal.pdf"
}

###

# @name getMyApplications
# Voir mes candidatures soumises
GET {{baseUrl}}/applications/me
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name checkHasApplied
# Vérifier si j'ai déjà postulé à une opportunité spécifique
GET {{baseUrl}}/applications/check/opp-201
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name getApplicationsByOpportunity
# Récupérer toutes les candidatures sur un projet (Mentor/Admin uniquement)
GET {{baseUrl}}/applications/opportunity/opp-201
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name updateApplicationStatus
# Mettre à jour le statut d'une candidature (APPROVED, REJECTED, PENDING)
PATCH {{baseUrl}}/applications/app-101/status
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
    "status": "APPROVED"
}
