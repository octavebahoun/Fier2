### ------------------------------------------------------------
### MODULE : AUTHENTICATION
### ------------------------------------------------------------

# @name register
# Inscription (Email, Password, Nom, Prénom, ID de la Branche choisie)
POST {{baseUrl}}/auth/register
Content-Type: {{contentType}}

{
    "email": "dev.test+tisto2@fieri.com",
    "password": "Password123!",
    "firstName": "Tisto",
    "lastName": "Dev",
    "branchId": 1
}

#Résultat
#Si utilisateur enregistré
# {
#   "message": "Cet email est déjà utilisé",
#   "error": "Conflict",
#   "statusCode": 409
# }

# sinon

# {
#   "success": true,
#   "message": "Inscription réussie",
#   "data": {
#     "id": 4,
#     "firstname": "Tisto",
#     "lastname": "Dev",
#     "email": "dev.test+tisto2@fieri.com",
#     "isActive": true,
#     "branchId": 1,
#     "createdAt": "2026-05-23T03:29:39.856Z",
#     "updatedAt": "2026-05-23T03:29:39.856Z"
#   }
# }

###

# @name login
# Connexion pour obtenir le jeton JWT
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
    "email": "dev.test+tisto@fieri.com",
    "password": "Password123!"
}

#Résultat
# {
#   "success": true,
#   "message": "Connexion réussie",
#   "data": {
#     "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOjMsImVtYWlsIjoiZGV2LnRlc3QrdGlzdG9AZmllcmkuY29tIiwiaWF0IjoxNzc5NTA3MDA1LCJleHAiOjE3Nzk1OTM0MDV9.KDXLvcTpPlfapLdfiH8TaLUUt77QLOXQgOc-yEFccQI",
#     "member": {
#       "id": 3,
#       "email": "dev.test+tisto@fieri.com",
#       "firstName": "Tisto",
#       "lastName": "Dev"
#     }
#   }
# }

### Capture automatique du Token après le login
@authToken = {{login.response.body.data.access_token}}


### ------------------------------------------------------------
### MODULE : MEMBERS (Routes Protégées)
### ------------------------------------------------------------

# @name getProfile
# Voir mon profil (Nécessite le Token dans le Header)
GET {{baseUrl}}/members/me
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

#Résultat
# {
#   "success": true,
#   "message": "Profil récupéré",
#   "data": {
#     "id": 3,
#     "email": "dev.test+tisto@fieri.com"
#   }
# }

### ------------------------------------------------------------
### MODULE : ORGANIZATION (Création / POST)
### ------------------------------------------------------------

# @name createCountry
# Créer un pays (Ex: Bénin)
POST {{baseUrl}}/countries
Content-Type: {{contentType}}

{
    "name": "Niger"
}

#Résultat
# {
#   "success": true,
#   "message": "Pays créé avec succès",
#   "data": {
#     "id": 4,
#     "name": "Niger",
#     "createdAt": "2026-05-23T03:31:25.549Z",
#     "updatedAt": "2026-05-23T03:31:25.549Z"
#   }
# }

###

# @name createUniversity
# Créer une université liée au pays (Utilise l'ID du pays créé, ex: 1)
POST {{baseUrl}}/universities
Content-Type: {{contentType}}

{
    "name": "Université Abdou Moumouni (UAM)",
    "countryId": 4
}

#Résultat
# {
#   "success": true,
#   "message": "Université créée avec succès",
#   "data": {
#     "id": 6,
#     "name": "Université Abdou Moumouni (UAM)",
#     "countryId": 4,
#     "createdAt": "2026-05-23T03:33:23.603Z",
#     "updatedAt": "2026-05-23T03:33:23.603Z"
#   }
# }

###

# @name createBranch
# Créer une branche liée à l'université (Utilise l'ID de l'université, ex: 1)
POST {{baseUrl}}/branches
Content-Type: {{contentType}}

{
    "name": "Electronique embarquée",
    "universityId": 6
}

#Résultat
# {
#   "success": true,
